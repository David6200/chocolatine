name: Chocolatine

on:
  push:
  pull_request:

env:
  MIRROR_SSH_URL: ${{ secrets.MIRROR_SSH_URL }}
  EXECUTABLES: "mysh"   # change this if needed

jobs:

  check_compilation_and_coding_style:
    if: >
      !startsWith(github.ref, 'refs/heads/no-ga/') &&
      github.repository != env.MIRROR_SSH_URL

    runs-on: ubuntu-latest
    container: epitechcontent/epitest-docker

    steps:

      - name: Checkout repository
        uses: actions/checkout@v3

      - name: Run coding style checker
        run: banana-check-repo > coding_style.txt || true

      - name: Fail if coding style errors
        run: |
          if [ -s coding_style.txt ]; then
            exit 1
          fi

      - name: Compile project
        run: make
        timeout-minutes: 2
        env:
          CC: epiclang

      - name: Clean project
        run: make clean

      - name: Check executables
        run: |
          IFS=',' read -ra EXE <<< "$EXECUTABLES"
          for exe in "${EXE[@]}"; do
            if [ ! -f "$exe" ]; then
              echo "::error file=$exe::Executable not found"
              exit 1
            fi
            if [ ! -x "$exe" ]; then
              echo "::error file=$exe::File is not executable"
              exit 1
            fi
          done

  run_tests:
    needs: check_compilation_and_coding_style
    if: >
      !startsWith(github.ref, 'refs/heads/no-ga/') &&
      github.repository != env.MIRROR_SSH_URL

    runs-on: ubuntu-latest
    container: epitechcontent/epitest-docker

    steps:

      - name: Checkout repository
        uses: actions/checkout@v3

      - name: Run tests
        run: make tests_run
        timeout-minutes: 2